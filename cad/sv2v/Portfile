PortSystem          1.0
PortGroup           eda-github 1.0
PortGroup           github 1.0

github.setup        zachjs sv2v 0.0.13 v
github.tarball_from archive
name                sv2v
revision            1

categories          cad lang
license             BSD
maintainers         {icanalytica.com:degnan @bpdegnan} openmaintainer
platforms           macosx

# Built FROM SOURCE with ghc-prebuilt, natively on both architectures
# (revision 0 repackaged upstream's x86_64-only release binary and needed
# Rosetta on Apple Silicon).
supported_archs     x86_64 arm64

description         SystemVerilog to Verilog-2005 converter
long_description    sv2v converts synthesizable SystemVerilog into plain \
                    Verilog-2005 that tools with weak SV support (iverilog, \
                    older yosys frontends) can read: always_ff/always_comb, \
                    logic, interfaces, packages, parametrized types, etc. \
                    Haskell program, built offline with the MacPorts \
                    ghc-prebuilt toolchain and a fully vendored, pinned \
                    Hackage dependency closure (10 tarballs - no network and \
                    no Hackage index at build time).

homepage            https://github.com/zachjs/sv2v

# ============================================================================
# Vendored Hackage closure (everything non-boot that the cabal solver picked
# on ghc 9.14.1, including the alex/happy build tools, so the MacPorts
# alex/happy ports are NOT needed). Each entry: {name version}. The tarballs
# extract into ${workpath} and are listed in cabal.project as LOCAL packages
# with `active-repositories: none` - the solver never consults a repository.
#
# The raw tarballs carry stale upper bounds on boot libraries (base < 4.22
# etc.) that Hackage relaxed via metadata revisions our offline build never
# sees; pre-configure rewrites those bounds in the vendored .cabal files
# (same effect as the Hackage revisions, pinned versions make it safe).
#
# On a version bump: with ghc/cabal-prebuilt installed, run a NETWORKED
#   cabal build --dry-run
# in the new source tree, update this list to the plan it prints, refresh
# checksums, and re-test. sv2v's githash usage has a no-git fallback
# (tGitInfoCwdTry), so tarball builds report the plain cabal version.
# ============================================================================
set hackage_deps {
    {alex 3.5.4.2}
    {cmdargs 0.10.22}
    {githash 0.1.7.0}
    {happy 2.2}
    {happy-lib 2.2}
    {hashable 1.5.1.0}
    {primitive 0.9.1.0}
    {th-compat 0.1.7}
    {vector 0.13.2.0}
    {vector-stream 0.1.0.1}
}

