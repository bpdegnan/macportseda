# Register each Hackage tarball as a tagged distfile.
set _n 0
foreach dep ${hackage_deps} {
    lassign ${dep} dname dver
    incr _n
    master_sites-append https://hackage.haskell.org/package/${dname}-${dver}/:hk${_n}
    distfiles-append    ${dname}-${dver}.tar.gz:hk${_n}
}
unset _n

depends_build-append \
    port:ghc-prebuilt \
    port:cabal-prebuilt
# The ghc-prebuilt runtime links these MacPorts libs into produced binaries.
depends_lib-append \
    port:libiconv \
    port:libffi

set cabalhome       ${workpath}/.cabal-home
set cabalenv        "CABAL_DIR=${cabalhome} HOME=${workpath} PATH=${cabalhome}/bin:${prefix}/bin:/usr/bin:/bin"

use_configure       no

pre-build {
    # cabal locates ghc/ghc-pkg by name; expose the prebuilt toolchain the
    # same way the stock haskell_cabal PortGroup does for bootstrap builds.
    set ghcver [lindex [regexp -all -inline {[0-9.]+} \
        [exec ${prefix}/bin/ghc-prebuilt --version]] 0]
    xinstall -d ${cabalhome}/bin
    ln -sf ${prefix}/lib/ghc-${ghcver}-prebuilt/bin/ghc-${ghcver} \
        ${cabalhome}/bin/ghc
    ln -sf ${prefix}/lib/ghc-${ghcver}-prebuilt/bin/ghc-pkg-${ghcver} \
        ${cabalhome}/bin/ghc-pkg

    # Two fixups on the vendored .cabal files:
    # 1. Relax stale boot-library upper bounds (offline stand-in for the
    #    Hackage metadata revisions; see header).
    # 2. Strip test-suite/benchmark stanzas AND test/bench-named
    #    sub-libraries (e.g. vector's `library benchmarks-O2`): cabal solves
    #    ALL components of local packages regardless of tests:/benchmarks:
    #    False, and those components want tasty et al, which is a large tree
    #    deliberately not vendored. Named sub-libraries that are real build
    #    deps (happy-lib's grammar/frontend/backend-*) are kept.
    set awkstrip {BEGIN{skip=0} /^[A-Za-z]/{skip = (tolower($0) ~ /^(test-suite|benchmark)/ || tolower($0) ~ /^library[ \t]+[a-z0-9-]*(test|bench)/) ? 1 : 0} skip==0{print}}
    foreach dep ${hackage_deps} {
        lassign ${dep} dname dver
        foreach cf [glob -nocomplain ${workpath}/${dname}-${dver}/*.cabal] {
            reinplace -E {s@(base|template-haskell|ghc-prim|deepseq|bytestring|text|containers|filepath|directory|process|transformers|mtl|array|stm|exceptions)([[:space:]]*(>=?[[:space:]]*[0-9.]+[[:space:]]*)?&&[[:space:]]*<[[:space:]]*)[0-9][0-9.]*@\1\29@g} ${cf}
            system "/usr/bin/awk [shellescape ${awkstrip}] [shellescape ${cf}] \
                > [shellescape ${cf}.stripped] && /bin/mv [shellescape ${cf}.stripped] [shellescape ${cf}]"
        }
    }

    # cabal.project: vendored dirs as local packages, no repositories at all.
    # tests/benchmarks MUST be off explicitly: local packages otherwise get
    # their test components solved, and vector's test-suite wants tasty (a
    # large tree deliberately NOT vendored).
    set fp [open ${worksrcpath}/cabal.project w]
    puts ${fp} "packages: ."
    foreach dep ${hackage_deps} {
        lassign ${dep} dname dver
        puts ${fp} "          ${workpath}/${dname}-${dver}"
    }
    puts ${fp} "active-repositories: none"
    puts ${fp} "tests: False"
    puts ${fp} "benchmarks: False"
    close ${fp}
}

build {
    system -W ${worksrcpath} \
        "env ${cabalenv} ${prefix}/bin/cabal-prebuilt build --offline \
         -j${build.jobs} exe:sv2v"
}

destroot {
    set bin [glob ${worksrcpath}/dist-newstyle/build/*/ghc-*/sv2v-${version}/x/sv2v/build/sv2v/sv2v]
    xinstall -m 755 ${bin} ${destroot}${prefix}/bin/sv2v
    set docdir ${prefix}/share/doc/${name}
    xinstall -d ${destroot}${docdir}
    xinstall -m 644 -W ${worksrcpath} \
        CHANGELOG.md LICENSE NOTICE README.md \
        ${destroot}${docdir}
}

# Smoke test: a SystemVerilog always_ff/logic module must convert to
# Verilog-2005 (always @(posedge ...) + reg).
test.run            yes
test {
    set sv ${workpath}/t.sv
    set fp [open ${sv} w]
    puts ${fp} "module t(input logic clk, d, output logic q);"
    puts ${fp} "always_ff @(posedge clk) q <= d;"
    puts ${fp} "endmodule"
    close ${fp}
    set bin [glob ${worksrcpath}/dist-newstyle/build/*/ghc-*/sv2v-${version}/x/sv2v/build/sv2v/sv2v]
    system "${bin} [shellescape ${sv}] > ${workpath}/t.v 2>${workpath}/t.err"
    set fp [open ${workpath}/t.v r]
    set out [read ${fp}]
    close ${fp}
    if {![string match "*always @(posedge clk)*" ${out}] ||
        ![string match "*output reg q*" ${out}]} {
        error "sv2v did not produce expected Verilog-2005: ${out}"
    }
}

livecheck.type      none
