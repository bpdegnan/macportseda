# -*- coding: utf-8; mode: tcl; tab-width: 4; indent-tabs-mode: nil; c-basic-offset: 4 -*- vim:fenc=utf-8:ft=tcl:et:sw=4:ts=4:sts=4

PortSystem          1.0
PortGroup           eda-github 1.0
PortGroup           cmake 1.1
PortGroup           github 1.0

github.setup        fmtlib fmt 12.1.0
github.tarball_from archive
name                eda-fmt
revision            0

categories          cad devel
license             MIT
maintainers         {icanalytica.com:degnan @bpdegnan} openmaintainer
platforms           macosx

description         {fmt} formatting library 12.x (private EDA prefix) for OpenROAD
long_description    The {fmt} C++ formatting library, version ${version}, built \
                    into the private prefix ${prefix}/libexec/eda. OpenROAD 26Q3 \
                    (via its slang SystemVerilog frontend) requires fmt >= 12.1, \
                    which is newer than the MacPorts fmt. Providing it here as \
                    eda-fmt lets OpenROAD's core, its bundled spdlog (eda-spdlog) \
                    and slang all share ONE fmt ABI, avoiding the fmt::v10/v12 \
                    symbol mismatch that a version-split otherwise causes.

homepage            https://fmt.dev/

checksums           rmd160  d238165e20e4f3373d6fbab9409b750d2312e444 \
                    sha256  ea7de4299689e12b6dddd392f9896f08fb0777ac7168897a244a6d6085043fea \
                    size    711419

set edaprefix       ${prefix}/libexec/eda
cmake.install_prefix ${edaprefix}

# Consumed by OpenROAD's C++20 build (clang-19 + libc++ 19 headers, same recipe
# as the kicad/openroad ports). Build fmt the same way so any std types on the
# ABI boundary match exactly.
configure.compiler        macports-clang-19
configure.cxxflags-append -nostdinc++ \
                          -isystem ${prefix}/libexec/llvm-19/include/c++/v1

configure.args-append \
    -DBUILD_SHARED_LIBS=ON \
    -DFMT_TEST=OFF \
    -DFMT_DOC=OFF \
    -DFMT_FUZZ=OFF

livecheck.type      none
