# -*- coding: utf-8; mode: tcl; tab-width: 4; indent-tabs-mode: nil; c-basic-offset: 4 -*- vim:fenc=utf-8:ft=tcl:et:sw=4:ts=4:sts=4

PortSystem          1.0
PortGroup           cmake 1.1
PortGroup           github 1.0
# boost181 (>=1.78, C++20-clean) via the boost PortGroup. This also sets
# conflicts_build boost, which is REQUIRED: the umbrella `boost` (1.76) installs
# C++20-incompatible headers at ${prefix}/include/boost that otherwise shadow
# boost181 during the compile (boost 1.76 asio uses the removed std::result_of).
# Deactivate it for the build:  sudo port -f deactivate boost  (reactivate after).
PortGroup           boost 1.0
boost.version       1.81

# SHADOWING GATE #2: the MacPorts `spdlog` port (built +fmt_external against the
# old MacPorts fmt) installs headers to ${prefix}/include/spdlog. Some system
# dep drags ${prefix}/include onto the compile line as a plain -I, which beats
# the -isystem path of eda-spdlog, so those stale headers would win and re-create
# the fmt::v10-vs-v12 symbol mismatch. eda-spdlog/eda-fmt (fmt 12) live in the
# private eda prefix; to keep the MacPorts spdlog headers from shadowing them,
# deactivate it for the build too:  sudo port -f deactivate spdlog  (reactivate
# after). (There is no ${prefix}/include/fmt, so no fmt gate is needed.)

github.setup        The-OpenROAD-Project OpenROAD 26Q3
github.tarball_from archive
name                openroad
version             26Q3
revision            3
distname            OpenROAD-26Q3
worksrcdir          OpenROAD-26Q3

categories          cad
license             BSD
maintainers         {icanalytica.com:degnan @bpdegnan} openmaintainer

description         OpenROAD RTL-to-GDS digital place-and-route
long_description    OpenROAD is an integrated chip physical-design tool \
                    (floorplanning, placement, CTS, routing, timing) for \
                    RTL-to-GDS digital flows. Built from the 26Q3 release via \
                    CMake (not Bazel), linking a private-prefix or-tools/LEMON.

homepage            https://theopenroadproject.org/

# 26Q3 vendors several git submodules that are NOT in the GitHub archive
# tarball; fetch each pinned commit as a distfile and drop it into place. The
# slang SystemVerilog frontend (third-party/slang-elab) IS required by the CMake
# build and itself nests slang + fmt (no deeper nesting). See charon for the
# same multi-distfile pattern.
set sta_sha         8572175ac45c42ce8d3d772f73bbb059786b9c66
set abc_sha         d527cfab4ad731b767ea0a2be2021d920d3afece
set slangelab_sha   82effc8d9541be69e1ed3ec44759a4449f5d9247
set slang_sha       f04e81565793c768b747a8fd058f3e7aeceee1b5
set fmt_sha         553ec11ec06fbe0beebfbb45f9dc3c9eabd83d28
master_sites-append \
    https://github.com/The-OpenROAD-Project/OpenSTA/archive/:sta \
    https://github.com/The-OpenROAD-Project/abc/archive/:abc \
    https://github.com/povik/sv-elab/archive/:slangelab \
    https://github.com/MikePopoloski/slang/archive/:slang \
    https://github.com/fmtlib/fmt/archive/:fmt
distfiles-append    ${sta_sha}.tar.gz:sta ${abc_sha}.tar.gz:abc \
                    ${slangelab_sha}.tar.gz:slangelab \
                    ${slang_sha}.tar.gz:slang ${fmt_sha}.tar.gz:fmt

