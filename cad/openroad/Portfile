post-extract {
    file delete -force ${worksrcpath}/src/sta
    move ${workpath}/OpenSTA-${sta_sha} ${worksrcpath}/src/sta
    file delete -force ${worksrcpath}/third-party/abc
    move ${workpath}/abc-${abc_sha} ${worksrcpath}/third-party/abc
    # slang frontend: slang-elab (upstream repo povik/yosys-slang was renamed
    # to povik/sv-elab, changing the archive's top-level directory name), and
    # its nested slang + fmt
    file delete -force ${worksrcpath}/third-party/slang-elab
    move ${workpath}/sv-elab-${slangelab_sha} ${worksrcpath}/third-party/slang-elab
    file delete -force ${worksrcpath}/third-party/slang-elab/third_party/slang
    move ${workpath}/slang-${slang_sha} ${worksrcpath}/third-party/slang-elab/third_party/slang
    file delete -force ${worksrcpath}/third-party/slang-elab/third_party/fmt
    move ${workpath}/fmt-${fmt_sha} ${worksrcpath}/third-party/slang-elab/third_party/fmt
}

set edaprefix       ${prefix}/libexec/eda

# SHADOWING GATE #3: or-tools' generated *.pb.h (in eda-or-tools) require
# protobuf 6.31, but the MacPorts `protobuf3-cpp` port (protobuf 3.21) installs
# headers at ${prefix}/include/google/protobuf. Targets pull in ${prefix}/include
# as a plain -I (e.g. via TCL_INCLUDE_PATH), which beats the -isystem path of the
# eda bundle, so the old protobuf headers shadow eda's and the .pb.h fail to
# compile (missing EnumTraitsT/ClassDataFull). CMake dedups a competing
# include_directories(BEFORE) back to -isystem, so prepending doesn't help.
# Deactivate protobuf3-cpp for the build:  sudo port -f deactivate protobuf3-cpp
# (its only dependent is kicad; reactivate after). abseil/re2 (also in the
# or-tools bundle) are NOT installed under ${prefix}/include, so they need no gate.
#
# SHADOWING GATE #4: OpenROAD builds its OWN OpenSTA fork (src/sta), but the
# standalone MacPorts `OpenSTA` port installs headers at ${prefix}/include/sta.
# Those get pulled in ahead of the fork (again via the -I${prefix}/include on
# tcl-linking targets), and since they are a DIFFERENT file with the same
# `#pragma once`, the dbSta SWIG wrapper ends up including LibertyClass.hh et al.
# twice -> "redefinition" errors. Deactivate it for the build:
#   sudo port -f deactivate OpenSTA   (reactivate after).

depends_build-append \
    path:bin/bison:bison \
    path:bin/flex:flex \
    port:swig \
    port:llvm-19

depends_lib-append \
    port:eda-or-tools \
    port:eda-lemon \
    port:eda-fmt \
    port:eda-spdlog \
    port:tcl \
    port:eigen3 \
    port:cudd \
    port:yaml-cpp \
    port:gtest \
    port:readline \
    port:zlib \
    port:libomp \
    port:python313
# Boost: or-tools' bundled Boost 1.87 is static-only and lacks iostreams, so we
# point OpenROAD at the versioned boost181 (1.81, complete, >=1.78) via Boost_DIR
# below. boost181 lives in its own libexec prefix, so no boost-PortGroup
# conflicts_build deactivation gate is needed.
# Qt5 (GUI) is left optional. OpenMP is REQUIRED by src/drt and src/gpl; the
# MacPorts libomp installs to ${prefix}/lib/libomp/libomp.dylib (a subdir), which
# find_package(OpenMP) does not locate, so it got the -fopenmp compile flag but
# no link library -> undefined ___kmpc_* at the final link. Point it at libomp
# explicitly (OpenMP_* below) and add the lib dir to the link path.

# OpenROAD 26Q3 requires C++20; the Ventura CLT libc++ (15) lacks parts of it,
# so build with MacPorts clang-19 + its libc++ 19 headers (same recipe as the
# kicad port), linking the system libc++ runtime.
configure.compiler        macports-clang-19
configure.cxxflags-append -nostdinc++ \
                          -isystem ${prefix}/libexec/llvm-19/include/c++/v1 \
                          -DBOOST_STACKTRACE_GNU_SOURCE_NOT_REQUIRED

# Boost.Stacktrace (pulled in by src/utl's logger) #errors out unless it knows
# `_Unwind_Backtrace` is reachable without _GNU_SOURCE. macOS/libc++ provides
# that symbol via libSystem's unwinder, so tell Boost so directly.

# or-tools' libraries live in the private eda prefix and are referenced as
# @rpath/...; add that rpath so the openroad binary resolves libortools.
configure.ldflags-append  -Wl,-rpath,${edaprefix}/lib \
                          -L${prefix}/lib/libomp -lomp

# NB: a single path only — MacPorts does NOT quote ';' in configure.args, so a
# semicolon-separated CMake list splits the shell command. ${prefix} is already
# in CMAKE_SYSTEM_PREFIX_PATH, so we only add the private eda prefix here.
cmake.build_type    Release
configure.args-append \
    -DCMAKE_PREFIX_PATH=${edaprefix} \
    -DENABLE_TESTS=OFF \
    -DLINK_TIME_OPTIMIZATION=OFF \
    -DUSE_SYSTEM_ABC=OFF \
    -DUSE_SYSTEM_OPENSTA=OFF \
    -DUSE_EXTERNAL_FMT=ON \
    -DUSE_SYSTEM_BOOST=ON \
    -DBoost_DIR=${prefix}/libexec/boost/1.81/lib/cmake/Boost-1.81.0 \
    -DBOOST_ROOT=${prefix}/libexec/boost/1.81 \
    -DBoost_NO_SYSTEM_PATHS=ON \
    -DPython3_EXECUTABLE=${prefix}/bin/python3.13 \
    -DTCL_LIBRARY=${prefix}/lib/libtcl8.6.dylib \
    -DTCL_INCLUDE_PATH=${prefix}/include \
    -DOpenMP_CXX_FLAGS=-fopenmp=libomp \
    -DOpenMP_CXX_LIB_NAMES=omp \
    -DOpenMP_omp_LIBRARY=${prefix}/lib/libomp/libomp.dylib

# OpenROAD statically links its bundled OpenSTA fork into bin/openroad, but its
# CMake also installs that fork's standalone artifacts (bin/sta, include/sta/*,
# lib/libOpenSTA.a) into the prefix. Those clobber the separate MacPorts OpenSTA
# port and pollute ${prefix}; the openroad deliverable is just bin/openroad (as
# in mainstream OpenROAD packages). Strip them so openroad and OpenSTA coexist.
post-destroot {
    file delete -force ${destroot}${prefix}/bin/sta
    file delete -force ${destroot}${prefix}/include/sta
    file delete -force ${destroot}${prefix}/lib/libOpenSTA.a
}

livecheck.type      none
