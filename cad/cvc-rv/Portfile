# -*- coding: utf-8; mode: tcl; tab-width: 4; indent-tabs-mode: nil; c-basic-offset: 4 -*- vim:fenc=utf-8:ft=tcl:et:sw=4:ts=4:sts=4

PortSystem          1.0
PortGroup           eda-github 1.0
PortGroup           github 1.0

github.setup        d-m-bailey cvc 1.1.7 v
github.tarball_from archive
name                cvc-rv
revision            0

categories          cad science
license             GPL-3+
maintainers         {icanalytica.com:degnan @bpdegnan} openmaintainer
platforms           macosx

description         CVC_RV circuit validity checker (ERC on CDL netlists)
long_description    CVC_RV performs electrical rule checks - voltage domain \
                    errors, floating gates, forward-biased diodes, and other \
                    reliability hazards - on CDL/SPICE netlists extracted from \
                    layout. The tapeout sanity check the rest of the flow \
                    (DRC/LVS/STA) does not cover. Named cvc-rv to avoid the \
                    MacPorts cvc3/cvc4/cvc5 SMT solvers - the binary is cvc_rv.

homepage            https://github.com/d-m-bailey/cvc

checksums           rmd160  726f2c1efe758d3c64949076e3abadcb1823b596 \
                    sha256  3e2fc0c072ca7934ea3d4aa43a360df8e09a86458cb4d5f87aa4d9050b1e3ad3 \
                    size    329790

# GitHub archive ships no configure; regenerate.
use_autoreconf      yes
autoreconf.args     -fvi

# MUST build with GCC/libstdc++, not clang/libc++: mmappable_vector.h pokes
# libstdc++ internals (_M_impl, _M_get_Tp_allocator) that libc++ lacks.
# gcc13 is already this tree's Fortran/charon toolchain. (GCC also treats
# `__block` in the bundled obstack as an ordinary identifier, unlike clang.)
configure.compiler  macports-gcc-13

post-patch {
    # obstack.c includes the GCC-internal 'stdint-gcc.h'; use <stdint.h>.
    reinplace "s|stdint-gcc.h|stdint.h|" ${worksrcpath}/src/obstack.c
}

depends_build-append \
    port:autoconf \
    port:automake \
    port:libtool \
    port:flex \
    port:bison

test.run            yes
test {
    system "${worksrcpath}/src/cvc_rv --version > ${workpath}/cvcver.txt 2>&1 || true"
    set fp [open ${workpath}/cvcver.txt r]
    set out [read ${fp}]
    close ${fp}
    if {![string match -nocase "*cvc*" ${out}]} {
        error "cvc_rv did not run: ${out}"
    }
}

livecheck.type      none
