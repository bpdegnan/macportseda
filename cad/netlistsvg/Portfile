extract.suffix      .tgz
distname            ${name}-${version}
master_sites        https://registry.npmjs.org/${name}/-/
checksums           ${distname}${extract.suffix} \
                    sha256  f261a9840e8c244ab6721917081bda04138e500b6d5727e672ba1b635ee9ceec \
                    size    277040

# Register every dep tarball as a distfile. Scoped packages (@types/*) live
# under a different registry path than their filename suggests, so each dep
# gets its own tagged master_sites entry.
set nsite 0
foreach dep ${npm_deps} {
    lassign ${dep} dname dfile dsha dsize
    incr nsite
    master_sites-append https://registry.npmjs.org/${dname}/-/:npm${nsite}
    distfiles-append    ${dfile}:npm${nsite}
    checksums-append    ${dfile} sha256 ${dsha} size ${dsize}
}

# Only the main tarball is auto-extracted (root dir "package"); deps are
# placed into node_modules by post-extract.
extract.only        ${distname}${extract.suffix}
worksrcdir          package

# node is needed only at run time; nothing is compiled.
depends_run         path:bin/node:nodejs22

post-extract {
    foreach dep ${npm_deps} {
        lassign ${dep} dname dfile dsha dsize
        set dest ${worksrcpath}/node_modules/${dname}
        xinstall -d ${dest}
        # `system`, not Tcl exec: trace mode blocks raw exec of /usr/bin tools
        system "/usr/bin/tar -xzf [shellescape ${distpath}/${dfile}] \
            --strip-components=1 -C [shellescape ${dest}]"
    }
}

use_configure       no
build               {}

destroot {
    set modroot ${prefix}/lib/node_modules/${name}
    xinstall -d ${destroot}${modroot} ${destroot}${prefix}/bin
    copy {*}[glob ${worksrcpath}/*] ${destroot}${modroot}

    # npm tarballs ship bin scripts mode 644; npm normally fixes that at
    # install time, so do it here, and pin the shebang to the MacPorts node.
    foreach script {netlistsvg.js exportLayout.js} {
        set f ${destroot}${modroot}/bin/${script}
        file attributes ${f} -permissions 0755
        reinplace "s|#!/usr/bin/env node|#!${prefix}/bin/node|" ${f}
    }
    ln -s ${modroot}/bin/netlistsvg.js ${destroot}${prefix}/bin/netlistsvg
    ln -s ${modroot}/bin/exportLayout.js ${destroot}${prefix}/bin/netlistsvg-dumplayout
}

test.run            yes
test {
    set tj ${workpath}/test.json
    set fp [open ${tj} w]
    puts ${fp} {{"modules":{"top":{"ports":{"a":{"direction":"input","bits":[2]},"b":{"direction":"input","bits":[3]},"y":{"direction":"output","bits":[4]}},"cells":{"and1":{"type":"$and","port_directions":{"A":"input","B":"input","Y":"output"},"connections":{"A":[2],"B":[3],"Y":[4]}}}}}}}
    close ${fp}
    system "${prefix}/bin/node [shellescape ${worksrcpath}/bin/netlistsvg.js] \
        [shellescape ${tj}] -o [shellescape ${workpath}/test.svg]"
    if {![file exists ${workpath}/test.svg]} {
        error "netlistsvg did not produce an SVG"
    }
}

livecheck.type      none
